		<style token="COMMENT_KEYWORD" fg="FFFFFF" bold="false" italic="true"/>
		<style token="COMMENT_MARKUP" fg="FFFFFF" bold="false" italic="true"/>
		<style token="DATA_TYPE" fg="5A575B" bold="true" italic="false"/>
		<style token="FUNCTION" fg="7A777B" bold="true" italic="false"/>
		<style token="LITERAL_BOOLEAN" fg="FFD866" bold="true" italic="false"/>
		<style token="LITERAL_NUMBER_DECIMAL_INT" fg="FFF886" bold="true" italic="false"/>
		<style token="LITERAL_NUMBER_FLOAT" fg="FFF886" bold="true" italic="false"/>
