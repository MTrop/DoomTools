<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE RSyntaxTheme SYSTEM "theme.dtd">

<RSyntaxTheme version="1.0">
	<background color="363337"/>
	<caret color="FFD866"/>
	<selection fg="FFD866" useFG="false" bg="5B595C"/>
	<currentLineHighlight color="020202" fade="false"/>
	<marginLine fg="DCDCDA"/>
	<markAllHighlight color="202020"/>
	<markOccurrencesHighlight color="202020" border="false"/>
	<matchedBracket fg="FCFCFA" bg="202020" highlightBoth="false" animate="true"/>
	<hyperlinks fg="FFD866"/>
	<secondaryLanguages>
		<language index="1" bg="403E41"/>
		<language index="2" bg="605E61"/>
		<language index="3" bg="807E81"/>
	</secondaryLanguages>

	<gutterBorder color="2D2A2E"/>
	<lineNumbers fg="FCFCFA" currentFG="FFD866"/>
	<foldIndicator fg="EAEAE9" armedFg="CACAC9" iconBg="EAEAE9"/>
