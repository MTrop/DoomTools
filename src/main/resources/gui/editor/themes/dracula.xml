<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE RSyntaxTheme SYSTEM "theme.dtd">

<RSyntaxTheme version="1.0">
	<background color="3A3D4C"/>
	<caret color="DDDDDD"/>
	<selection fg="F8F8F2" useFG="false" bg="6272A4"/>
	<currentLineHighlight color="3B4565" fade="false"/>
	<marginLine fg="BDBDBD"/>
	<markAllHighlight color="515A75"/>
	<markOccurrencesHighlight color="515A75" border="false"/>
	<matchedBracket fg="DDDDDD" bg="515A75" highlightBoth="false" animate="true"/>
	<hyperlinks fg="FF79C6"/>
	<secondaryLanguages>
		<language index="1" bg="414450"/>
		<language index="2" bg="616470"/>
		<language index="3" bg="818490"/>
	</secondaryLanguages>

	<gutterBorder color="414450"/>
	<lineNumbers fg="DDDDDD" currentFG="F8F8F2"/>
	<foldIndicator fg="CECECE" armedFg="AEAEAE" iconBg="CECECE"/>
	<iconRowHeader activeLineRange="EEEEEE"/>

	<tokenStyles>
