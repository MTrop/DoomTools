		<style token="MARKUP_CDATA_DELIMITER" fg="BDBDBD" bold="false" italic="false"/>
		<style token="MARKUP_ENTITY_REFERENCE" fg="FDFDFD" bold="false" italic="false"/>
		<style token="OPERATOR" fg="DDDDDD" bold="false" italic="false"/>
		<style token="PREPROCESSOR" fg="FDFDFD" bold="false" italic="false"/>
		<style token="REGEX" fg="848DAB" bold="false" italic="false"/>
