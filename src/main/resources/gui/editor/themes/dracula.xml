		<style token="COMMENT_KEYWORD" fg="FDFDFD" bold="false" italic="true"/>
		<style token="COMMENT_MARKUP" fg="FDFDFD" bold="false" italic="true"/>
		<style token="DATA_TYPE" fg="646D8B" bold="true" italic="false"/>
		<style token="FUNCTION" fg="848DAB" bold="true" italic="false"/>
		<style token="LITERAL_BOOLEAN" fg="FF79C6" bold="true" italic="false"/>
		<style token="LITERAL_NUMBER_DECIMAL_INT" fg="FF99E6" bold="true" italic="false"/>
		<style token="LITERAL_NUMBER_FLOAT" fg="FF99E6" bold="true" italic="false"/>
		<style token="LITERAL_NUMBER_HEXADECIMAL" fg="FF99E6" bold="true" italic="false"/>
