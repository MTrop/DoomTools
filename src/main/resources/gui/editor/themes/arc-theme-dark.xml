		<style token="MARKUP_TAG_DELIMITER" fg="DDDDDD" bold="false" italic="false"/>
		<style token="MARKUP_TAG_NAME" fg="DDDDDD" bold="false" italic="false"/>
		<style token="MARKUP_TAG_ATTRIBUTE" fg="BDBDBD" bold="false" italic="false"/>
		<style token="MARKUP_TAG_ATTRIBUTE_VALUE" fg="4699FB" bold="false" italic="false"/>
		<style token="MARKUP_COMMENT" fg="BDBDBD" bold="false" italic="false"/>
		<style token="MARKUP_DTD" fg="BDBDBD" bold="false" italic="false"/>
		<style token="MARKUP_PROCESSING_INSTRUCTION" fg="BDBDBD" bold="false" italic="false"/>
		<style token="MARKUP_CDATA" fg="BDBDBD" bold="false" italic="false"/>
		<style token="MARKUP_CDATA_DELIMITER" fg="BDBDBD" bold="false" italic="false"/>
		<style token="MARKUP_ENTITY_REFERENCE" fg="FDFDFD" bold="false" italic="false"/>
		<style token="OPERATOR" fg="DDDDDD" bold="false" italic="false"/>
		<style token="PREPROCESSOR" fg="FDFDFD" bold="false" italic="false"/>
		<style token="REGEX" fg="7A8295" bold="false" italic="false"/>
		<style token="SEPARATOR" fg="BDBDBD" bold="false" italic="false"/>
		<style token="VARIABLE" fg="DDDDDD" bold="false" italic="false"/>
		<style token="WHITESPACE" fg="BDBDBD" bold="false" italic="false"/>

		<style token="ERROR_IDENTIFIER" fg="DDDDDD" bg="C75450" bold="true" italic="false"/>
		<style token="ERROR_NUMBER_FORMAT" fg="4699FB" bg="C75450" bold="true" italic="false"/>
		<style token="ERROR_STRING_DOUBLE" fg="4699FB" bg="C75450" bold="true" italic="false"/>
