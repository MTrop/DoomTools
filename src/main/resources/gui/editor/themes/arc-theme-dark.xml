<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE RSyntaxTheme SYSTEM "theme.dtd">

<RSyntaxTheme version="1.0">
	<background color="474C5B"/>
	<caret color="DDDDDD"/>
	<selection fg="FFFFFF" useFG="false" bg="2679DB"/>
	<currentLineHighlight color="000000" fade="false"/>
	<marginLine fg="BDBDBD"/>
	<markAllHighlight color="202020"/>
	<markOccurrencesHighlight color="202020" border="false"/>
	<matchedBracket fg="DDDDDD" bg="202020" highlightBoth="false" animate="true"/>
	<hyperlinks fg="2679DB"/>
	<secondaryLanguages>
		<language index="1" bg="474C5B"/>
		<language index="2" bg="676C7B"/>
		<language index="3" bg="878C9B"/>
	</secondaryLanguages>

	<gutterBorder color="383C4A"/>
	<lineNumbers fg="DDDDDD" currentFG="FFFFFF"/>
	<foldIndicator fg="CECECE" armedFg="AEAEAE" iconBg="CECECE"/>
	<iconRowHeader activeLineRange="EEEEEE"/>

	<tokenStyles>
		<style token="IDENTIFIER" fg="DDDDDD" bold="false" italic="false"/>
		<style token="RESERVED_WORD" fg="7A8295" bold="true" italic="false"/>
		<style token="RESERVED_WORD_2" fg="7A8295" bold="true" italic="false"/>
		<style token="ANNOTATION" fg="7A8295" bold="true" italic="false"/>
		<style token="COMMENT_DOCUMENTATION" fg="FDFDFD" bold="false" italic="true"/>
		<style token="COMMENT_EOL" fg="DDDDDD" bold="false" italic="true"/>
		<style token="COMMENT_MULTILINE" fg="DDDDDD" bold="false" italic="true"/>
		<style token="COMMENT_KEYWORD" fg="FDFDFD" bold="false" italic="true"/>
		<style token="COMMENT_MARKUP" fg="FDFDFD" bold="false" italic="true"/>
		<style token="DATA_TYPE" fg="5A6275" bold="true" italic="false"/>
		<style token="FUNCTION" fg="7A8295" bold="true" italic="false"/>
		<style token="LITERAL_BOOLEAN" fg="2679DB" bold="true" italic="false"/>
		<style token="LITERAL_NUMBER_DECIMAL_INT" fg="4699FB" bold="true" italic="false"/>
		<style token="LITERAL_NUMBER_FLOAT" fg="4699FB" bold="true" italic="false"/>
		<style token="LITERAL_NUMBER_HEXADECIMAL" fg="4699FB" bold="true" italic="false"/>
		<style token="LITERAL_STRING_DOUBLE_QUOTE" fg="4699FB" bold="false" italic="false"/>
		<style token="LITERAL_CHAR" fg="4699FB" bold="false" italic="false"/>
