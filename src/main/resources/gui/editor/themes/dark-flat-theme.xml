	<selection fg="EEEEEE" useFG="false" bg="2A5285"/>
	<currentLineHighlight color="000000" fade="false"/>
	<marginLine fg="ACACAC"/>
	<markAllHighlight color="202020"/>
	<markOccurrencesHighlight color="202020" border="false"/>
