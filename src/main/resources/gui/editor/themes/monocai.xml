		<style token="DATA_TYPE" fg="5B555F" bold="true" italic="false"/>
		<style token="FUNCTION" fg="7B757F" bold="true" italic="false"/>
		<style token="LITERAL_BOOLEAN" fg="50A3ED" bold="true" italic="false"/>
		<style token="LITERAL_NUMBER_DECIMAL_INT" fg="70C3FF" bold="true" italic="false"/>
