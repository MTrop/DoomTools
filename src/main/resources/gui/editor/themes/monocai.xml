<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE RSyntaxTheme SYSTEM "theme.dtd">

<RSyntaxTheme version="1.0">
	<background color="37343A"/>
	<caret color="FCFCFB"/>
	<selection fg="FCFCFB" useFG="false" bg="756C7A"/>
	<currentLineHighlight color="4C4B4C" fade="false"/>
	<marginLine fg="DCDCDB"/>
	<markAllHighlight color="5F5F5F"/>
	<markOccurrencesHighlight color="5F5F5F" border="false"/>
