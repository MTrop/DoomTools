		<style token="MARKUP_COMMENT" fg="BFBFC0" bold="false" italic="false"/>
		<style token="MARKUP_DTD" fg="BFBFC0" bold="false" italic="false"/>
		<style token="MARKUP_PROCESSING_INSTRUCTION" fg="BFBFC0" bold="false" italic="false"/>
		<style token="MARKUP_CDATA" fg="BFBFC0" bold="false" italic="false"/>
