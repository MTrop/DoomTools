<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE RSyntaxTheme SYSTEM "theme.dtd">

<RSyntaxTheme version="1.0">
	<background color="3C3D3D"/>
	<caret color="DFDFE0"/>
	<selection fg="F9FCFF" useFG="false" bg="1D7BED"/>
	<currentLineHighlight color="0E0E0E" fade="false"/>
	<marginLine fg="BFBFC0"/>
	<markAllHighlight color="212121"/>
	<markOccurrencesHighlight color="212121" border="false"/>
	<matchedBracket fg="DFDFE0" bg="212121" highlightBoth="false" animate="true"/>
	<hyperlinks fg="428EE1"/>
	<secondaryLanguages>
		<language index="1" bg="3C3D3D"/>
		<language index="2" bg="5C5D5D"/>
		<language index="3" bg="7C7D7D"/>
	</secondaryLanguages>

	<gutterBorder color="323333"/>
	<lineNumbers fg="DFDFE0" currentFG="F9FCFF"/>
	<foldIndicator fg="CFCFD0" armedFg="AFAFB0" iconBg="CFCFD0"/>
	<iconRowHeader activeLineRange="EFEFF0"/>

	<tokenStyles>
