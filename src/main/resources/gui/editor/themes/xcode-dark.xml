		<style token="COMMENT_MULTILINE" fg="DFDFE0" bold="false" italic="true"/>
		<style token="COMMENT_KEYWORD" fg="FFFFFF" bold="false" italic="true"/>
		<style token="COMMENT_MARKUP" fg="FFFFFF" bold="false" italic="true"/>
		<style token="DATA_TYPE" fg="5C5C5C" bold="true" italic="false"/>
		<style token="FUNCTION" fg="7C7C7C" bold="true" italic="false"/>
		<style token="LITERAL_BOOLEAN" fg="1D7BED" bold="true" italic="false"/>
		<style token="LITERAL_NUMBER_DECIMAL_INT" fg="3D9BFF" bold="true" italic="false"/>
		<style token="LITERAL_NUMBER_FLOAT" fg="3D9BFF" bold="true" italic="false"/>
		<style token="LITERAL_NUMBER_HEXADECIMAL" fg="3D9BFF" bold="true" italic="false"/>
