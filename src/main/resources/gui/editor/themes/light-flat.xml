<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE RSyntaxTheme SYSTEM "theme.dtd">

<RSyntaxTheme version="1.0">
	<background color="FFFFFF"/>
	<caret color="333333"/>
	<selection fg="000000" useFG="false" bg="B8D9FF"/>
	<currentLineHighlight color="EFEFEF" fade="false"/>
	<marginLine fg="535353"/>
	<markAllHighlight color="FFFFFF"/>
	<markOccurrencesHighlight color="FFFFFF" border="false"/>
	<matchedBracket fg="333333" bg="FFFFFF" highlightBoth="false" animate="true"/>
	<hyperlinks fg="5C85CC"/>
	<secondaryLanguages>
		<language index="1" bg="FCFCFD"/>
		<language index="2" bg="DCDCDD"/>
		<language index="3" bg="BCBCBD"/>
	</secondaryLanguages>

	<gutterBorder color="EEEEF2"/>
	<lineNumbers fg="333333" currentFG="000000"/>
	<foldIndicator fg="AEAEB1" armedFg="CECED1" iconBg="AEAEB1"/>
	<iconRowHeader activeLineRange="CECED1"/>

	<tokenStyles>
