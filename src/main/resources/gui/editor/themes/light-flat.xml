		<style token="COMMENT_MULTILINE" fg="333333" bold="false" italic="true"/>
		<style token="COMMENT_KEYWORD" fg="131313" bold="false" italic="true"/>
		<style token="COMMENT_MARKUP" fg="535353" bold="false" italic="true"/>
		<style token="DATA_TYPE" fg="C5C5C5" bold="true" italic="false"/>
		<style token="FUNCTION" fg="E5E5E5" bold="true" italic="false"/>
		<style token="LITERAL_BOOLEAN" fg="5397E6" bold="true" italic="false"/>
		<style token="LITERAL_NUMBER_DECIMAL_INT" fg="3377C6" bold="true" italic="false"/>
		<style token="LITERAL_NUMBER_FLOAT" fg="3377C6" bold="true" italic="false"/>
		<style token="LITERAL_NUMBER_HEXADECIMAL" fg="3377C6" bold="true" italic="false"/>
